  "lines": [
    {
      "line": 1,
      "target": "Recherche jeune fille pour garder mes enfants le soir.",
      "base": "Busco chica joven para cuidar a mis hijos por la tarde.",
      "pronunciation": ".. jénfill... mesantán"
    },
    {
      "line": 2,
      "target": "Téléphoner le matin au 20. 31. 56",
      "base": "Telefonear por la mañana al 203156.",
      "pronunciation": ".. vèn tranteën sènkank'sis"
    },
    {
      "line": 3,
      "target": "Je vends un canapé et deux fauteuils modernes. Prix à débattre.",
      "base": "Vendo un sofá y 2 sillones modernos. Precio a convenir (debatir).",
      "pronunciation": "..van...fotëy... pri"
    },
    {
      "line": 4,
      "target": "A louer. Petit studio. Calme et clair. Salle de bains.",
      "base": "Alquilo (Para alquilar). Pequeño estudio. Tranquilo y luminoso (claro). Baño (Sala de baño).",
      "pronunciation": "a lué péti sal dé bèn"
    },
    {
      "line": 5,
      "target": "Ecrire à Mme DELAYE, 3 boulevard Malesherbes, Paris huitième.",
      "base": "Escribir a Sra. DELAYE, 3 boulevard Malesherbes, París 8.",
      "pronunciation": ".. malserb'"
    },
    {
      "line": 6,
      "target": "-Bonjour Madame. Je vous appelle au sujet de votre annonce.",
      "base": "Buenos días señora. La llamo con respecto al (a su) anuncio.",
      "pronunciation": "..osüjé ... votr anons"
    },
    {
      "line": 7,
      "target": "-Très bien. Comment vous appelez-vous ?",
      "base": "Muybien. ¿ Cómo se llama (usted) ?"
    },
    {
      "line": 8,
      "target": "-Je m'appelle Martine Lenoir, Madame.",
      "base": "Me llamo Martine Lenoir, señora."
    },
    {
      "line": 9,
      "target": "-Et quel âge avez-vous , Martine ?",
      "base": "¿ Y qué edad tiene (usted), Martine ?"
    },
    {
      "line": 10,
      "target": "-J'ai quatorze ans, Madame.",
      "base": "Tengo 14 años, señora.",
      "pronunciation": "..katorz"
    },
    {
      "line": 11,
      "target": "-Oh, mais vous êtes beaucoup trop jeune !",
      "base": "¡Ah!; Pero usted es (mucho) demasiado joven !",
      "pronunciation": ".. vuzèt bocú tro"
    },
    {
      "line": 12,
      "target": "Je suis désolée . Au revoir.",
      "base": "Lo siento. Adiós.",
      "pronunciation": ".. dezolé"
    }
  ],
